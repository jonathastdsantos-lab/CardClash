<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/apk/res/auto"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Flame trail behind card -->
    <path
        android:pathData="M 256 460 C 130 380 130 200 230 110 C 250 180 290 220 330 250 C 360 280 360 360 320 410 C 300 440 280 455 256 460 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="256.0"
                android:startY="460.0"
                android:endX="256.0"
                android:endY="110.0">
                <item android:offset="0.0" android:color="#FFF7C2" />
                <item android:offset="0.5" android:color="#FFD86B" />
                <item android:offset="1.0" android:color="#00FF7A3D" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Tilted card group translated to center of flame -->
    <group
        android:translateX="256"
        android:translateY="260"
        android:rotation="-15">

        <!-- Card board (gold/cream gradient) -->
        <path
            android:pathData="M -73,-135 L 73,-135 A 22,22 0 0 1 95,-113 L 95,113 A 22,22 0 0 1 73,135 L -73,135 A 22,22 0 0 1 -95,113 L -95,-113 A 22,22 0 0 1 -73,-135 Z"
            android:strokeColor="#7D1208"
            android:strokeWidth="3">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="0.0"
                    android:startY="-135.0"
                    android:endX="0.0"
                    android:endY="135.0">
                    <item android:offset="0.0" android:color="#FFF7E2" />
                    <item android:offset="1.0" android:color="#F5D57A" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Inner golden foil line -->
        <path
            android:pathData="M -69,-123 L 69,-123 A 14,14 0 0 1 83,-109 L 83,109 A 14,14 0 0 1 69,123 L -69,123 A 14,14 0 0 1 -83,109 L -83,-109 A 14,14 0 0 1 -69,-123 Z"
            android:strokeColor="#99B8821F"
            android:strokeWidth="2" />

        <!-- Star symbol center aligned -->
        <path
            android:pathData="M 0,-55 L 17,-17 L 58,-14 L 26,12 L 36,53 L 0,30 L -36,53 L -26,12 L -58,-14 L -17,-17 Z"
            android:fillColor="#7D1208" />

    </group>
</vector>
